# Day 08 Lab — RAG Pipeline
# Copy file này thành .env và điền API key

# === LLM Provider ===
LLM_PROVIDER=openai
OPENAI_API_KEY=123  # Điền key của bạn ở đây

# === Jina AI (Embedding & Reranker) ===
# Lấy key tại https://jina.ai/
JINA_API_KEY=123

# === Model Selection ===
LLM_MODEL=gpt-4o-mini
# Jina Embedding model (vế sau là model name, ví dụ: jina-embeddings-v2-base-en)
JINA_EMBEDDING_MODEL=123
# Jina Rerank model
JINA_RERANK_MODEL=123

# === Vector Store ===
CHROMA_DB_DIR=./chroma_db
